# Copy to .env and adjust. docker-compose reads this automatically.

# Shared secret for TURN REST API credentials.
# MUST be identical to `static-auth-secret` in coturn/coturn.conf.
TURN_SECRET=2285427

# Comma-separated ICE URLs returned to clients.
# Use your server's public hostname/IP here.
TURN_URLS=turn:turn.example.com:3478

# Credential lifetime in seconds (default: 24h).
TURN_TTL=86400

# Comma-separated allowed CORS origins (the frontends calling this API).
CORS_ORIGINS=http://localhost:3000

# --- Database (Postgres) ---
# For local dev, use `localhost` and run `docker compose up -d db`.
# Inside docker-compose the API talks to the `db` service, so DB_HOST is set to
# `db` there. In prod, point these at your managed Postgres and set DB_SSL=true.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=turn

# Enable TLS to the database (set true for managed/prod Postgres).
DB_SSL=false

# Auto-run pending migrations on application boot (handy in containers).
# Locally, leave false and run `npm run migration:run` explicitly.
DB_MIGRATIONS_RUN=false
