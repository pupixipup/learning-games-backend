# Copy to .env and adjust. docker-compose reads this automatically.

# Shared secret for TURN REST API credentials.
# MUST be identical to `static-auth-secret` in coturn/coturn.conf.
TURN_SECRET=2285427

# Comma-separated ICE URLs returned to clients.
# Use your server's public hostname/IP here.
TURN_URLS=turn:turn.example.com:3478

# Credential lifetime in seconds (default: 24h).
TURN_TTL=86400

# Comma-separated allowed CORS origins (the frontends calling this API).
CORS_ORIGINS=http://localhost:3000
